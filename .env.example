# =============================================================================
#  .env.example  —  Gabarit des SECRETS et paramètres d'environnement
# -----------------------------------------------------------------------------
#  Copier ce fichier en `.env` et renseigner les valeurs.
#  Les secrets ne figurent QUE dans .env ; la configuration non secrète est
#  dans config.yaml, qui référence ces variables par ${NOM}.
# =============================================================================

# --- PostgreSQL (mémoire épisodique) ---
POSTGRES_DB=osint
POSTGRES_USER=osint
POSTGRES_PASSWORD=change-me-en-prod

# --- Service de modèle (résolu via LiteLLM) ---
# Topologie locale : Ollama tourne sur l'HÔTE, atteint via host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_API_KEY=                       # vide en local ; clé du fournisseur en centrale/cloud

# --- Console d'administration ---
# Requis pour activer /admin. Si vide, l'espace admin est désactivé (503).
ADMIN_PASSWORD=change-me

# --- n8n (planification, profil "full") ---
N8N_USER=admin
N8N_PASSWORD=change-me

# --- Port de l'API exposé sur l'hôte ---
# L'interface enquêteur et la console admin sont servies par l'API sur ce port.
APP_PORT=8000
